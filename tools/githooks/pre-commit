#!/usr/bin/env bash
set -Eeuo pipefail

BRANCH="$(git rev-parse --abbrev-ref HEAD)"

# Block protected branches
if [[ "$BRANCH" == "dev" || "$BRANCH" == "main" ]]; then
  echo "❌ Direct commits to $BRANCH are not allowed."
  exit 1
fi

# Enforce branch naming
if ! [[ "$BRANCH" =~ ^(feature|bugfix|patch)/(blue|green|yellow)/[0-9]{4}-[0-9]{2}-[0-9]{2}/.+$ ]]; then
  echo "❌ Invalid branch name."
  echo "Required: {type}/{agentColor}/{yyyy-mm-dd}/{short-scope}"
  exit 1
fi

FILES="$(git diff --cached --name-only --diff-filter=A || true)"
STAGED_ALL="$(git diff --cached --name-only || true)"

# Block forbidden new-file locations (repo-root aware)
for FILE in $FILES; do
  if [[ "$FILE" =~ ^server/[^/]+$ ]]; then
    echo "❌ Do not create files directly under server/ (use server/src or an existing module dir)."
    echo "   Offending: $FILE"
    exit 1
  fi

  if [[ "$FILE" =~ ^front-end/[^/]+$ ]]; then
    echo "❌ Do not create files directly under front-end/ (use front-end/src)."
    echo "   Offending: $FILE"
    exit 1
  fi

  if [[ "$FILE" =~ ^[^/]+$ ]]; then
    case "$FILE" in
      README.md|AGENT_WORKFLOW.md|LICENSE|.gitignore|CHANGELOG.md|VERSION|Makefile|docker-compose.yml|ecosystem.config.js|.editorconfig) ;;
      *)
        echo "❌ Do not create new files directly under repo root. Put them in an approved directory."
        echo "   Offending: $FILE"
        exit 1
        ;;
    esac
  fi
done

# Block secrets + keys + creds + build artifacts
for FILE in $STAGED_ALL; do
  if [[ "$FILE" =~ (^|/)\.env($|\.|-) ]]; then
    echo "❌ Refusing to commit .env files."
    echo "   Offending: $FILE"
    exit 1
  fi

  if [[ "$FILE" =~ \.(pem|key|p12|pfx|crt|cer)$ ]]; then
    echo "❌ Refusing to commit private keys/certs."
    echo "   Offending: $FILE"
    exit 1
  fi

  if [[ "$FILE" =~ (^|/)id_rsa($|[^a-zA-Z0-9]) ]]; then
    echo "❌ Refusing to commit SSH private keys."
    echo "   Offending: $FILE"
    exit 1
  fi

  if [[ "$FILE" =~ (^|/)node_modules(/|$) ]]; then
    echo "❌ Refusing to commit node_modules."
    echo "   Offending: $FILE"
    exit 1
  fi

  if [[ "$FILE" =~ (^|/)(dist|build)(/|$) ]]; then
    echo "❌ Refusing to commit build artifacts (dist/build)."
    echo "   Offending: $FILE"
    exit 1
  fi
done

echo "✅ Pre-commit checks passed."
