/**
 * Database Connection Example
 * 
 * This is an example file showing what the db export should look like.
 * Replace the import in interactiveReports.ts if your database connection is located elsewhere
 * or has a different structure.
 */

import { Pool } from 'pg';

// Example using pg (PostgreSQL)
const pool = new Pool({
  host: process.env.DB_HOST || 'localhost',
  port: parseInt(process.env.DB_PORT || '5432'),
  database: process.env.DB_NAME || 'orthodoxmetrics_db',
  user: process.env.DB_USER || 'postgres',
  password: process.env.DB_PASS || '',
});

export const db = {
  query: (text: string, params?: any[]) => pool.query(text, params),
};

// Or if using a different database library, adapt accordingly
