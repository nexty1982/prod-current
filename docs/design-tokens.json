{
  "$schema": "https://schemas.tokens.studio/2.0.0/schema.json",
  "$metadata": {
    "name": "Orthodox Metrics Design System",
    "description": "Complete design token system for Orthodox Metrics platform",
    "version": "1.0.0"
  },
  "global": {
    "colors": {
      "primary": {
        "purple": {
          "$type": "color",
          "$value": "#2d1b4e",
          "$description": "Primary brand color - Orthodox purple"
        },
        "purple-10": {
          "$type": "color",
          "$value": "rgba(45, 27, 78, 0.1)",
          "$description": "Primary purple at 10% opacity"
        },
        "purple-80": {
          "$type": "color",
          "$value": "rgba(45, 27, 78, 0.8)",
          "$description": "Primary purple at 80% opacity"
        }
      },
      "accent": {
        "gold": {
          "$type": "color",
          "$value": "#d4af37",
          "$description": "Accent gold color for CTAs and highlights"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "#2d1b4e",
          "$description": "Primary text color (headings)"
        },
        "body": {
          "$type": "color",
          "$value": "#4a5565",
          "$description": "Body text color"
        },
        "secondary": {
          "$type": "color",
          "$value": "#6a7282",
          "$description": "Secondary/muted text"
        },
        "on-dark": {
          "$type": "color",
          "$value": "#ffffff",
          "$description": "Text on dark backgrounds"
        },
        "on-dark-muted": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.8)",
          "$description": "Muted text on dark backgrounds"
        },
        "on-gold": {
          "$type": "color",
          "$value": "#2d1b4e",
          "$description": "Text on gold backgrounds"
        }
      },
      "background": {
        "white": {
          "$type": "color",
          "$value": "#ffffff",
          "$description": "Primary white background"
        },
        "gray-50": {
          "$type": "color",
          "$value": "#f9fafb",
          "$description": "Light gray background for alternating sections"
        },
        "gray-100": {
          "$type": "color",
          "$value": "#f3f4f6",
          "$description": "Subtle gray for borders and dividers"
        }
      },
      "border": {
        "light": {
          "$type": "color",
          "$value": "#f3f4f6",
          "$description": "Light border color"
        },
        "accent": {
          "$type": "color",
          "$value": "#d4af37",
          "$description": "Accent border (gold)"
        },
        "purple-10": {
          "$type": "color",
          "$value": "rgba(45, 27, 78, 0.1)",
          "$description": "Subtle purple border"
        },
        "white-20": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.2)",
          "$description": "Subtle white border on dark backgrounds"
        }
      },
      "gradient": {
        "hero-purple": {
          "$type": "color",
          "$value": "linear-gradient(160.048deg, rgb(45, 27, 78) 0%, rgb(48, 29, 82) 11.111%, rgb(51, 31, 85) 22.222%, rgb(54, 34, 89) 33.333%, rgb(58, 36, 92) 44.444%, rgb(61, 38, 96) 55.556%, rgb(64, 40, 100) 66.667%, rgb(67, 42, 104) 77.778%, rgb(71, 45, 107) 88.889%, rgb(74, 47, 111) 100%)",
          "$description": "Hero section purple gradient"
        },
        "card-subtle": {
          "$type": "color",
          "$value": "linear-gradient(136.599deg, rgb(249, 250, 251) 0%, rgb(255, 255, 255) 100%)",
          "$description": "Subtle card gradient"
        }
      }
    },
    "typography": {
      "fontFamilies": {
        "primary": {
          "$type": "fontFamily",
          "$value": "Inter, sans-serif",
          "$description": "Primary font family for UI and body text"
        },
        "serif": {
          "$type": "fontFamily",
          "$value": "Georgia, serif",
          "$description": "Serif font for headings and display text"
        }
      },
      "fontWeights": {
        "regular": {
          "$type": "fontWeight",
          "$value": "400"
        },
        "medium": {
          "$type": "fontWeight",
          "$value": "500"
        }
      },
      "fontSize": {
        "xs": {
          "$type": "dimension",
          "$value": "12px"
        },
        "sm": {
          "$type": "dimension",
          "$value": "14px"
        },
        "base": {
          "$type": "dimension",
          "$value": "16px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "18px"
        },
        "xl": {
          "$type": "dimension",
          "$value": "20px"
        },
        "2xl": {
          "$type": "dimension",
          "$value": "24px"
        },
        "3xl": {
          "$type": "dimension",
          "$value": "32px"
        },
        "4xl": {
          "$type": "dimension",
          "$value": "48px"
        }
      },
      "lineHeight": {
        "tight": {
          "$type": "dimension",
          "$value": "20px"
        },
        "snug": {
          "$type": "dimension",
          "$value": "22.75px"
        },
        "normal": {
          "$type": "dimension",
          "$value": "24px"
        },
        "relaxed": {
          "$type": "dimension",
          "$value": "26px"
        },
        "loose": {
          "$type": "dimension",
          "$value": "28px"
        },
        "extra-loose": {
          "$type": "dimension",
          "$value": "29.25px"
        },
        "display": {
          "$type": "dimension",
          "$value": "48px"
        }
      },
      "letterSpacing": {
        "tight": {
          "$type": "dimension",
          "$value": "-1.2px"
        },
        "normal": {
          "$type": "dimension",
          "$value": "0px"
        }
      },
      "textStyles": {
        "h1": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.serif}",
            "fontWeight": "{typography.fontWeights.regular}",
            "fontSize": "{typography.fontSize.4xl}",
            "lineHeight": "{typography.lineHeight.display}",
            "letterSpacing": "{typography.letterSpacing.tight}"
          }
        },
        "h2": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.serif}",
            "fontWeight": "{typography.fontWeights.regular}",
            "fontSize": "{typography.fontSize.4xl}",
            "lineHeight": "{typography.lineHeight.display}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        },
        "h3": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.primary}",
            "fontWeight": "{typography.fontWeights.medium}",
            "fontSize": "{typography.fontSize.xl}",
            "lineHeight": "{typography.lineHeight.loose}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        },
        "h4": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.primary}",
            "fontWeight": "{typography.fontWeights.medium}",
            "fontSize": "{typography.fontSize.lg}",
            "lineHeight": "{typography.lineHeight.relaxed}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        },
        "body-large": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.primary}",
            "fontWeight": "{typography.fontWeights.regular}",
            "fontSize": "{typography.fontSize.xl}",
            "lineHeight": "{typography.lineHeight.loose}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        },
        "body": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.primary}",
            "fontWeight": "{typography.fontWeights.regular}",
            "fontSize": "{typography.fontSize.lg}",
            "lineHeight": "{typography.lineHeight.extra-loose}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        },
        "body-small": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.primary}",
            "fontWeight": "{typography.fontWeights.regular}",
            "fontSize": "{typography.fontSize.base}",
            "lineHeight": "{typography.lineHeight.normal}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        },
        "small": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.primary}",
            "fontWeight": "{typography.fontWeights.regular}",
            "fontSize": "{typography.fontSize.sm}",
            "lineHeight": "{typography.lineHeight.tight}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        },
        "button": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{typography.fontFamilies.primary}",
            "fontWeight": "{typography.fontWeights.medium}",
            "fontSize": "{typography.fontSize.base}",
            "lineHeight": "{typography.lineHeight.normal}",
            "letterSpacing": "{typography.letterSpacing.normal}"
          }
        }
      }
    },
    "spacing": {
      "1": {
        "$type": "dimension",
        "$value": "4px",
        "$description": "Extra small spacing"
      },
      "2": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "Small spacing"
      },
      "3": {
        "$type": "dimension",
        "$value": "12px",
        "$description": "Small-medium spacing"
      },
      "4": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "Medium spacing"
      },
      "5": {
        "$type": "dimension",
        "$value": "20px"
      },
      "6": {
        "$type": "dimension",
        "$value": "24px",
        "$description": "Medium-large spacing"
      },
      "8": {
        "$type": "dimension",
        "$value": "32px",
        "$description": "Large spacing"
      },
      "10": {
        "$type": "dimension",
        "$value": "40px"
      },
      "12": {
        "$type": "dimension",
        "$value": "48px",
        "$description": "Extra large spacing"
      },
      "16": {
        "$type": "dimension",
        "$value": "64px",
        "$description": "2XL spacing"
      },
      "20": {
        "$type": "dimension",
        "$value": "80px",
        "$description": "3XL spacing"
      },
      "30": {
        "$type": "dimension",
        "$value": "120px",
        "$description": "4XL spacing"
      },
      "35": {
        "$type": "dimension",
        "$value": "140px",
        "$description": "5XL spacing"
      }
    },
    "borderRadius": {
      "sm": {
        "$type": "dimension",
        "$value": "6px",
        "$description": "Small radius for subtle rounding"
      },
      "md": {
        "$type": "dimension",
        "$value": "10px",
        "$description": "Medium radius for buttons and small components"
      },
      "lg": {
        "$type": "dimension",
        "$value": "14px",
        "$description": "Large radius for icon containers"
      },
      "xl": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "Extra large radius for cards"
      },
      "2xl": {
        "$type": "dimension",
        "$value": "24px",
        "$description": "2XL radius for large cards"
      },
      "full": {
        "$type": "dimension",
        "$value": "9999px",
        "$description": "Fully rounded (pills, badges)"
      }
    },
    "shadows": {
      "sm": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "3px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.1)"
        },
        "$description": "Small shadow for subtle elevation"
      },
      "sm-secondary": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "2px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.1)"
        }
      },
      "md": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "10px",
          "blur": "15px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.1)"
        },
        "$description": "Medium shadow for cards and elevated components"
      },
      "md-secondary": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.1)"
        }
      },
      "lg": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "20px",
          "blur": "25px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.1)"
        },
        "$description": "Large shadow for prominent cards"
      },
      "lg-secondary": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "8px",
          "blur": "10px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.1)"
        }
      },
      "xl": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "25px",
          "blur": "50px",
          "spread": "-12px",
          "color": "rgba(0, 0, 0, 0.25)"
        },
        "$description": "Extra large shadow for hero elements"
      },
      "2xl": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "25px",
          "blur": "50px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.25)"
        },
        "$description": "2XL shadow for major CTA sections"
      }
    },
    "sizing": {
      "icon": {
        "xs": {
          "$type": "dimension",
          "$value": "16px"
        },
        "sm": {
          "$type": "dimension",
          "$value": "20px"
        },
        "md": {
          "$type": "dimension",
          "$value": "32px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "48px"
        },
        "xl": {
          "$type": "dimension",
          "$value": "64px"
        }
      },
      "iconContainer": {
        "sm": {
          "$type": "dimension",
          "$value": "36px"
        },
        "md": {
          "$type": "dimension",
          "$value": "48px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "64px"
        }
      },
      "button": {
        "height": {
          "$type": "dimension",
          "$value": "50px"
        },
        "height-lg": {
          "$type": "dimension",
          "$value": "58px"
        }
      }
    },
    "layout": {
      "container": {
        "sm": {
          "$type": "dimension",
          "$value": "640px"
        },
        "md": {
          "$type": "dimension",
          "$value": "768px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "1024px"
        },
        "xl": {
          "$type": "dimension",
          "$value": "1200px"
        },
        "2xl": {
          "$type": "dimension",
          "$value": "1280px"
        }
      },
      "grid": {
        "columns": {
          "$type": "number",
          "$value": "12"
        },
        "gutter": {
          "$type": "dimension",
          "$value": "32px"
        }
      }
    },
    "components": {
      "button": {
        "primary": {
          "backgroundColor": "{colors.accent.gold}",
          "textColor": "{colors.text.on-gold}",
          "borderRadius": "{borderRadius.md}",
          "paddingX": "{spacing.6}",
          "paddingY": "{spacing.3}",
          "shadow": ["{shadows.md}", "{shadows.md-secondary}"]
        },
        "secondary": {
          "backgroundColor": "{colors.primary.purple}",
          "textColor": "{colors.text.on-dark}",
          "borderRadius": "{borderRadius.md}",
          "paddingX": "{spacing.6}",
          "paddingY": "{spacing.3}",
          "shadow": ["{shadows.md}", "{shadows.md-secondary}"]
        }
      },
      "card": {
        "default": {
          "backgroundColor": "{colors.background.white}",
          "borderColor": "{colors.border.light}",
          "borderWidth": "1px",
          "borderRadius": "{borderRadius.xl}",
          "padding": "{spacing.8}",
          "shadow": ["{shadows.sm}", "{shadows.sm-secondary}"]
        },
        "elevated": {
          "backgroundColor": "{colors.background.white}",
          "borderColor": "{colors.border.light}",
          "borderWidth": "1px",
          "borderRadius": "{borderRadius.xl}",
          "padding": "{spacing.8}",
          "shadow": ["{shadows.md}", "{shadows.md-secondary}"]
        },
        "large": {
          "backgroundColor": "{colors.background.white}",
          "borderColor": "{colors.border.light}",
          "borderWidth": "1px",
          "borderRadius": "{borderRadius.2xl}",
          "padding": "{spacing.8}",
          "shadow": ["{shadows.lg}", "{shadows.lg-secondary}"]
        },
        "highlighted": {
          "backgroundColor": "{colors.background.white}",
          "borderColor": "{colors.border.accent}",
          "borderWidth": "2px",
          "borderRadius": "{borderRadius.xl}",
          "padding": "{spacing.8}",
          "shadow": ["{shadows.md}", "{shadows.md-secondary}"]
        }
      },
      "badge": {
        "default": {
          "backgroundColor": "{colors.primary.purple-10}",
          "textColor": "{colors.text.primary}",
          "borderRadius": "{borderRadius.full}",
          "paddingX": "{spacing.4}",
          "paddingY": "{spacing.2}"
        },
        "accent": {
          "backgroundColor": "{colors.accent.gold}",
          "textColor": "{colors.text.on-gold}",
          "borderRadius": "{borderRadius.full}",
          "paddingX": "{spacing.4}",
          "paddingY": "{spacing.2}",
          "shadow": ["{shadows.md}", "{shadows.md-secondary}"]
        }
      },
      "iconContainer": {
        "purple": {
          "backgroundColor": "{colors.primary.purple}",
          "size": "{sizing.iconContainer.lg}",
          "borderRadius": "{borderRadius.lg}",
          "shadow": ["{shadows.md}", "{shadows.md-secondary}"]
        },
        "gold": {
          "backgroundColor": "{colors.accent.gold}",
          "size": "{sizing.iconContainer.lg}",
          "borderRadius": "{borderRadius.lg}",
          "shadow": ["{shadows.md}", "{shadows.md-secondary}"]
        }
      }
    }
  }
}

