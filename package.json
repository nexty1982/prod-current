{
  "name": "orthodox-metrics-scripts",
  "version": "1.0.0",
  "description": "Scripts for Orthodox Metrics project",
  "type": "module",
  "scripts": {
    "fix:imports": "node scripts/auto-fix-imports.mjs --apply",
    "fix:imports:dry": "node scripts/auto-fix-imports.mjs --dry",
    "fix:syntax": "node scripts/deep-sanitize.mjs",
    "scan:nonascii": "node scripts/scan-non-ascii.mjs",
    "build:hardened": "node scripts/build-harness.mjs",
    "features:integrate:dry": "cd UI/modernize/frontend && node ../../../scripts/integrate-features.mjs --zip ../features.zip --dry --prefer-alias @ --case-policy normalize",
    "features:integrate": "cd UI/modernize/frontend && node ../../../scripts/integrate-features.mjs --zip ../features.zip --apply --prefer-alias @ --case-policy normalize --remove-empties",
    "collect:md": "powershell -ExecutionPolicy Bypass -File scripts/collect-markdown.ps1",
    "consolidate:src": "node scripts/consolidate-duplicates.mjs --root \"Z:\\\\prod\\\\front-end\\\\src\"",
    "collect:om-src": "node scripts/collect-om-src.mjs --root \"Z:\\\\prod\\\\front-end\\\\src\"",
    "gather:to-consolidate": "npm run collect:md:consolidate && npm run consolidate:src && npm run collect:om-src:consolidate"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.0.0",
    "glob": "^10.3.0",
    "ts-morph": "^21.0.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "zip-lib": "^1.1.2"
  }
}
